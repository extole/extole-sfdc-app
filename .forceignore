# List files or directories below to ignore them when running force:source:push, force:source:pull, and force:source:status
# More information: https://developer.salesforce.com/docs/atlas.en-us.sfdx_dev.meta/sfdx_dev/sfdx_dev_exclude_source.htm
#

package.xml

# Never deploy Named Credentials or External Credentials — deploying these files resets
# stored tokens/secrets to placeholder values, breaking all API callouts immediately.
# Both are configured once manually at install time and must not be overwritten by deploys.
**/namedCredentials/**
**/externalCredentials/**

# LWC configuration files
**/jsconfig.json
**/.eslintrc.json

# LWC Jest
**/__tests__/**